  if (goBackButton) {
    goBackButton.click();
  }
  
  const initContinue = document.getElementById("election_id_button");
  if (initContinue) {
    initContinue.click();  
  }
} 

else if ((c == 1002 || c == 1003 || c == 8889) && candidateButton && !runningMateButton) { 
